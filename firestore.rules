rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funções auxiliares
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    
    // Função robusta para pegar o papel do usuário
    function getUserRole() {
      let profile = get(/databases/$(database)/documents/profiles/$(request.auth.uid));
      return profile != null ? profile.data.role : 'student';
    }

    function isTeacherOrAdmin() {
      return isSignedIn() && getUserRole() in ['teacher', 'admin'];
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    // Profiles: cada usuário lê/edita apenas o próprio. Admin lê todos.
    match /profiles/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow write: if isSignedIn() && (isOwner(userId) || isAdmin());
    }

    // Courses: qualquer um lê se aprovado; teacher cria/edita os seus. Admin lê/escreve todos.
    match /courses/{courseId} {
      allow read: if (resource.data.status in ['APROVADO', 'published']) || (isSignedIn() && (isOwner(resource.data.teacher_id) || isAdmin()));
      allow write: if isSignedIn() && (isTeacherOrAdmin() || isAdmin());
    }

    // Lessons: análogo a courses
    match /lessons/{lessonId} {
      allow read: if (resource.data.status in ['APROVADO', 'published']) || (isSignedIn() && (isAdmin() || (exists(/databases/$(database)/documents/courses/$(resource.data.course_id)) && get(/databases/$(database)/documents/courses/$(resource.data.course_id)).data.teacher_id == request.auth.uid)));
      allow write: if isSignedIn() && (isTeacherOrAdmin() || isAdmin());
    }

    // Enrollments: aluno lê as suas, permite criação pelo aluno
    match /enrollments/{enrollmentId} {
      allow read: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isTeacherOrAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Vendas Logs: Apenas Admin
    match /vendas_logs/{saleId} {
      allow read, write: if isAdmin();
    }

    // Sales (legacy/others): Aluno lê as suas
    match /sales/{saleId} {
      allow read: if isSignedIn() && (
        resource.data.studentId == request.auth.uid || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.studentId == request.auth.uid;
      allow update, delete: if false;
    }

    // Configurações Globais: Apenas Admin
    match /config/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}


