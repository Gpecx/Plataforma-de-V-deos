rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funções auxiliares
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function getUserRole() {
      return get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role;
    }
    function isTeacherOrAdmin() {
      return getUserRole() in ['teacher', 'admin'];
    }

    // Profiles: cada usuário lê/edita apenas o próprio
    match /profiles/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Courses: qualquer um lê publicados; teacher cria/edita os seus
    match /courses/{courseId} {
      allow read: if resource.data.status == 'published' || (isSignedIn() && isTeacherOrAdmin());
      allow write, create, delete: if isSignedIn() && isTeacherOrAdmin();
    }

    // Lessons: qualquer um lê; teacher escreve
    match /lessons/{lessonId} {
      allow read: if true;
      allow write, create, delete: if isSignedIn() && isTeacherOrAdmin();
    }

    // Enrollments: aluno lê as suas, teacher lê as dos seus cursos
    match /enrollments/{enrollmentId} {
      allow read: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isTeacherOrAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow write: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isTeacherOrAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.user_id == request.auth.uid || isTeacherOrAdmin()
      );
    }
  }
}
